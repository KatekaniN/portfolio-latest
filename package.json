{
  "name": "katekani-portfolio",
  "version": "1.0.0",
  "main": "server.js",
  "description": "Katekani Nyamandi's Portfolio - Windows 11 style interface with AI chat, weather, and contact features",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:html": "node scripts/build-html.js",
    "build:css": "node scripts/build-css.js",
    "build:js": "node scripts/build-js.js",
    "build": "npm run build:html && npm run build:css && npm run build:js",
    "prestart": "npm run build",
    "predev": "npm run build",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "railway:build": "npm install && npm run build",
    "railway:start": "npm start"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sendinblue/client": "^3.3.1",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "nodemailer": "^7.0.5",
    "pg": "^8.11.3",
    "resend": "^4.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KatekaniN/portfolio-2025.git"
  },
  "keywords": [],
  "author": "Katekani Nyamandi",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/KatekaniN/portfolio-2025/issues"
  },
  "homepage": "https://github.com/KatekaniN/portfolio-2025#readme"
}
